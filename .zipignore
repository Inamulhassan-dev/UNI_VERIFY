# Files and folders to EXCLUDE from the portable ZIP package

# Python
backend/.venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.Python
backend/pip-log.txt
backend/pip-delete-this-directory.txt
backend/.pytest_cache/

# Node.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.turbo/

# Database (will be created during setup)
backend/uni_verify.db
backend/uni_verify.db-journal

# Uploads (will be created during setup)
backend/uploads/*
!backend/uploads/.gitkeep

# Data warehouse (will be created during setup)
backend/data_warehouse/*
!backend/data_warehouse/.gitkeep

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.*.local

# Setup marker (will be created after setup)
.setup_complete

# Temporary files
*.tmp
*.temp
temp_input.txt
