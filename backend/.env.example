# ============================================================
# UNI-VERIFY Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# REQUIRED – change this to a long random secret before deploying!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Optional – defaults to SQLite in the backend directory
# DATABASE_URL=sqlite:///./uni_verify.db

# Optional – JWT token lifetime in minutes (default: 1440 = 24 h)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
